# Dashboard with volume mount for hot reload (Vite HMR).
# Docker Compose merges this with docker-compose.yml automatically.

services:
  dashboard:
    build:
      context: ./dashboard
      dockerfile: Dockerfile.dev
    volumes:
      - ./dashboard:/app
      - dashboard_node_modules:/app/node_modules
    ports:
      - "5174:5174"
    command: sh -c "npm install && npm run dev"

volumes:
  dashboard_node_modules:
